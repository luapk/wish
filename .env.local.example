# Vercel Blob — create a store at vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Modal backend URLs — printed after running: modal deploy modal_backend/app.py
# Format: https://<your-workspace>--cognitive-analyzer-<label>.modal.run
MODAL_ANALYZE_URL=https://YOUR_WORKSPACE--cognitive-analyzer-analyze.modal.run
MODAL_STATUS_URL=https://YOUR_WORKSPACE--cognitive-analyzer-status.modal.run

# Optional: shared secret for Modal auth (set the same value in Modal secrets)
MODAL_API_KEY=
